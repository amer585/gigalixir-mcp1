    if (stats.weeklyAvg >= 90) list.push({ icon: Crown, color: 'text-amber-500', bg: 'bg-amber-100', title: 'ملك الأسبوع', desc: 'أداء أسبوعي ممتاز' });
    if (stats.monthlyAvg >= 85) list.push({ icon: Star, color: 'text-violet-500', bg: 'bg-violet-100', title: 'نجم الشهر', desc: 'درجات شهرية عالية' });
    return list;
  }, [stats]);

  return (
