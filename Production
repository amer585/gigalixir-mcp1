        score: 8 + Math.floor(Math.random() * 3),
        maxScore: 10,
        status: Math.random() > 0.9 ? 'absent' : 'present',
        note: '',
        date: new Date(Date.now() - (10 - w) * 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0]
       });
    });
  }
  return assessments;
};

