                    <div className="absolute -bottom-2 -right-2 bg-green-500 border-4 border-white w-6 h-6 rounded-full"></div>
                </div>
                <div>
                    <h1 className="text-3xl md:text-4xl font-black text-slate-800 mb-2">{student.name}</h1>
                    <div className="flex flex-wrap items-center gap-3">
                        <span className="px-3 py-1 bg-slate-100 text-slate-600 rounded-full text-xs font-bold border border-slate-200">{student.grade}</span>
                        <span className="px-3 py-1 bg-white text-slate-400 rounded-full text-xs font-mono border border-slate-200">ID: {student.id}</span>
                    </div>
                </div>
            </div>

            {achievements.length > 0 && (
               <div className="flex gap-2 overflow-x-auto pb-2 lg:pb-0">
                  {achievements.map((badge, idx) => (
                    <div key={idx} className={`flex items-center gap-2 px-3 py-2 rounded-xl border border-transparent ${badge.bg} ${badge.color}`}>
                       <badge.icon className="w-4 h-4" />
                       <div className="flex flex-col">
                          <span className="text-[10px] font-black uppercase leading-none mb-0.5">{badge.title}</span>
