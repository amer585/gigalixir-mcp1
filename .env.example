# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GIGALIXIR_EMAIL: Registered email address for your Gigalixir account
GIGALIXIR_EMAIL=

# GIGALIXIR_API_KEY: API Key retrieved from Gigalixir CLI (gigalixir api_key:show)
GIGALIXIR_API_KEY=

# TURSO_DB_URL: The URL of your Turso database (e.g. libsql://mydatabase-myuser.turso.io)
TURSO_DB_URL=

# TURSO_AUTH_TOKEN: Turso DB authorization bearer token
TURSO_AUTH_TOKEN=

# GITHUB_TOKEN: GitHub Personal Access Token for repository and pull request tools
GITHUB_TOKEN=
